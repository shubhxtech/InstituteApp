<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration — Vertex Institute App
  =====================================================
  All traffic is HTTPS-only. Backend is served at https://vertex.iitmandi.co.in
  No cleartext HTTP exceptions are needed.
-->
<network-security-config>

    <!-- ── Production default: HTTPS only ─────────────────── -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust only the system CA store (public CAs like Let's Encrypt) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- ── Debug builds only ─────────────────────────────── -->
    <!--
        Allows user-installed CAs in debug mode
        so developers can inspect traffic with Charles / mitmproxy.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
